# export-image.sh
#!/bin/bash
set -euo pipefail

# Directories
BASE_DIR="/var/lib/containers/trivy"
IMAGE_DIR="$BASE_DIR/images"
DB_DIR="$BASE_DIR/db"
EXPORT_DB_DIR="$BASE_DIR/db_exports"

timestamp=$(date +"%Y%m%d-%H%M")
image="aquasec/trivy:latest"

mkdir -p "$IMAGE_DIR"
mkdir -p "$EXPORT_DB_DIR"

echo "=== Trivy Export Script ==="
echo "Timestamp: $timestamp"
echo

# --- Get Trivy version from the container ---
echo "Detecting Trivy version..."
version=$(docker run --rm "$image" --version | awk '/Version:/ {print $2}')

if [[ -z "$version" ]]; then
    echo "ERROR: Unable to detect Trivy version."
    exit 1
fi

echo "Detected Trivy version: $version"
echo

# --- Save Trivy image (still using :latest tag) ---
image_output="$IMAGE_DIR/trivy-${version}-${timestamp}.tar.gz"
echo "Saving Trivy image (tag: latest) to: $image_output"
docker save "aquasec/trivy:latest" | gzip > "$image_output"
echo "Image saved."
echo

# --- Zip the DB directory ---
if [[ ! -d "$DB_DIR" ]]; then
    echo "ERROR: Trivy DB directory not found at $DB_DIR"
    exit 1
fi

db_output="$EXPORT_DB_DIR/trivy-db-${timestamp}.zip"
echo "Zipping Trivy DB to: $db_output"
cd "$DB_DIR"
zip -r "$db_output" . >/dev/null
cd - >/dev/null
echo "DB zipped."
echo

# --- Cleanup older image files ---
echo "Cleaning older image files..."
find "$IMAGE_DIR" -type f -name "trivy-*.tar.gz" ! -name "$(basename "$image_output")" -exec rm -f {} \;
echo "Old images removed."
echo

# --- Cleanup older DB zip files ---
echo "Cleaning older DB zip files..."
find "$EXPORT_DB_DIR" -type f -name "trivy-db-*.zip" ! -name "$(basename "$db_output")" -exec rm -f {} \;
echo "Old DB zips removed."
echo

echo "=== Export Complete ==="
echo "Image: $image_output"
echo "DB:    $db_output"
echo


# export-reports.sh
#!/bin/bash

timestamp=$(date +"%Y%m%d-%H%M")
export_dir="/var/lib/containers/trivy/exports"
report_dir="/var/lib/containers/trivy/reports"

mkdir -p "$export_dir"

output="${export_dir}/trivy-reports-${timestamp}.zip"

zip -j "$output" "$report_dir"/*

echo "Export complete."
echo "ZIP file created at: $output"


# image-import.sh
#!/bin/bash
set -euo pipefail

BASE_DIR="/var/lib/containers/trivy"
IMAGE_DIR="$BASE_DIR/images"
DB_EXPORT_DIR="$BASE_DIR/db_exports"
DB_DIR="$BASE_DIR/db"

echo "=== Trivy Import Script ==="
echo

# --- Find newest image file ---
newest_image=$(ls -1t "$IMAGE_DIR"/trivy-*.tar.gz 2>/dev/null | head -n 1 || true)

if [[ -z "$newest_image" ]]; then
    echo "ERROR: No Trivy image files found in $IMAGE_DIR"
    exit 1
fi

echo "Newest image file: $newest_image"
echo

# --- Find newest DB zip ---
newest_db_zip=$(ls -1t "$DB_EXPORT_DIR"/trivy-db-*.zip 2>/dev/null | head -n 1 || true)

if [[ -z "$newest_db_zip" ]]; then
    echo "ERROR: No Trivy DB zip files found in $DB_EXPORT_DIR"
    exit 1
fi

echo "Newest DB zip: $newest_db_zip"
echo

# --- Remove old Trivy images from Docker ---
echo "Removing old Trivy images from Docker..."
docker images --format '{{.Repository}}:{{.Tag}} {{.ID}}' \
    | grep '^aquasec/trivy:' \
    | awk '{print $2}' \
    | xargs -r docker rmi -f || true
echo "Old images removed."
echo

# --- Load the new image ---
echo "Loading new Trivy image..."
gunzip -c "$newest_image" | docker load
echo "Image loaded."
echo

# --- Clean DB directory ---
echo "Cleaning old DB contents..."
rm -rf "$DB_DIR"/*
echo "DB directory cleared."
echo

# --- Extract new DB ---
echo "Extracting new DB..."
unzip -o "$newest_db_zip" -d "$DB_DIR" >/dev/null
echo "DB extracted."
echo

# --- Cleanup artifacts ---
echo "Removing imported artifacts..."
rm -f "$newest_image"
rm -f "$newest_db_zip"
echo "Artifacts removed."
echo

echo "=== Import Complete ==="
echo "Trivy image and DB updated successfully."
echo


