# scan-all-sbom.sh
#!/usr/bin/env bash
set -euo pipefail

report_dir="/var/lib/containers/trivy/reports"
template_dir="/var/lib/containers/trivy/templates"
timestamp=$(date +"%Y%m%d-%H%M%S")
hostname=$(hostname)

# Auto-detect running container images
images=$(docker ps --format '{{.Image}}' | sort -u)

for img in $images; do
  safe_name=$(echo "$img" | tr '/:' '_')
  sbom_json="${report_dir}/${safe_name}-sbom-${timestamp}.json"
  sbom_cdx="${report_dir}/${safe_name}-sbom-${timestamp}.cdx"
  sbom_html="${report_dir}/${safe_name}-sbom-${timestamp}.html"

  # CycloneDX SBOM
  docker run --rm \
    -v /var/lib/containers/trivy/db:/root/.cache/trivy/db \
    -v "$report_dir":/reports \
    -v /var/run/docker.sock:/var/run/docker.sock \
    aquasec/trivy:latest image \
      --skip-db-update \
      --skip-version-check \
      --format cyclonedx \
      --output "/reports/$(basename "$sbom_cdx")" \
      "$img"

  # JSON SBOM
  docker run --rm \
    -v /var/lib/containers/trivy/db:/root/.cache/trivy/db \
    -v "$report_dir":/reports \
    -v /var/run/docker.sock:/var/run/docker.sock \
    aquasec/trivy:latest image \
      --skip-db-update \
      --skip-version-check \
      --format json \
      --output "/reports/$(basename "$sbom_json")" \
      "$img"

  # HTML SBOM with hostname
  docker run --rm \
    -v /var/lib/containers/trivy/db:/root/.cache/trivy/db \
    -v "$report_dir":/reports \
    -v "$template_dir":/templates \
    -v /var/run/docker.sock:/var/run/docker.sock \
    aquasec/trivy:latest image \
      --skip-db-update \
      --skip-version-check \
      --format template \
      --template "@/templates/html.tpl" \
      --output "/reports/$(basename "$sbom_html")" \
      "$img"
done

