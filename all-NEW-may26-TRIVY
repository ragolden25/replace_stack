bash
#!/bin/bash
set -euo pipefail

BASE_DIR="/var/lib/containers/trivy"
IMAGE_DIR="$BASE_DIR/images"
DB_DIR="$BASE_DIR/db"
EXPORT_DB_DIR="$BASE_DIR/db_exports"

timestamp=$(date +"%Y%m%d-%H%M")
image="aquasec/trivy:latest"

mkdir -p "$IMAGE_DIR"
mkdir -p "$EXPORT_DB_DIR"

echo "=== Trivy Export Script ==="
echo "Timestamp: $timestamp"
echo

echo "Detecting Trivy version..."
version=$(docker run --rm "$image" --version | awk '/Version:/ {print $2}')

if [[ -z "$version" ]]; then
    echo "ERROR: Unable to detect Trivy version."
    exit 1
fi

echo "Detected Trivy version: $version"
echo

image_output="$IMAGE_DIR/trivy-${version}-${timestamp}.tar.gz"
echo "Saving Trivy image (tag: latest) to: $image_output"
docker save "aquasec/trivy:latest" | gzip > "$image_output"
echo "Image saved."
echo

if [[ ! -d "$DB_DIR" ]]; then
    echo "ERROR: Trivy DB directory not found at $DB_DIR"
    exit 1
fi

db_output="$EXPORT_DB_DIR/trivy-db-${timestamp}.zip"
echo "Zipping Trivy DB to: $db_output"
cd "$DB_DIR"
zip -r "$db_output" . >/dev/null
cd - >/dev/null
echo "DB zipped."
echo

echo "Cleaning older image files..."
find "$IMAGE_DIR" -type f -name "trivy-*.tar.gz" ! -name "$(basename "$image_output")" -exec rm -f {} \;
echo "Old images removed."
echo

echo "Cleaning older DB zip files..."
find "$EXPORT_DB_DIR" -type f -name "trivy-db-*.zip" ! -name "$(basename "$db_output")" -exec rm -f {} \;
echo "Old DB zips removed."
echo

echo "=== Export Complete ==="
echo "Image: $image_output"
echo "DB:    $db_output"
echo
