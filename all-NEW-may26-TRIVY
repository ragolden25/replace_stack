===== config/cve-filter-debian.jq =====

jq
# Debian‑aware CVE filter for Trivy JSON output

def lower: ascii_downcase;

def is_non_debian:
  (
    (.PrimaryURL // "" | lower | test("redhat|rhel|centos|fedora|alpine|ubuntu|amazon|suse|photon|oraclelinux|oracle"))
    or
    (.Vulnerability.DataSource.ID // "" | lower | test("redhat|alpine|ubuntu|amazon|suse|photon|oracle"))
  );

def debian_not_affected:
  (
    .Vulnerability.Custom != null
    and .Vulnerability.Custom.Debian != null
    and (.Vulnerability.Custom.Debian.Status // "" | lower) == "not affected"
  );

def debian_backported:
  (
    .Vulnerability.Custom != null
    and .Vulnerability.Custom.Debian != null
    and (.Vulnerability.Custom.Debian.Status // "" | lower) == "fixed"
    and (.FixedVersion // "") == ""
  );

.Results |= map(
  .Vulnerabilities |= map(
    select(
      (is_non_debian | not) and
      (debian_not_affected | not) and
      (debian_backported | not)
    )
  )
)
===== scripts/generate-csv.sh =====

bash
#!/bin/bash
set -euo pipefail

if [[ $# -ne 2 ]]; then
  echo "Usage: $0 <input-filtered-json> <output-csv>"
  exit 1
fi

INPUT="$1"
OUTPUT="$2"

if [[ ! -f "$INPUT" ]]; then
  echo "ERROR: Input file not found: $INPUT"
  exit 1
fi

echo "severity,cve,package,installed_version,fixed_version,description" > "$OUTPUT"

jq -r '
  .Results[]
  | select(.Vulnerabilities != null)
  | .Vulnerabilities[]
  | [
      .Vulnerability.Severity,
      .VulnerabilityID,
      .PkgName,
      (.InstalledVersion // "n/a"),
      (.FixedVersion // "n/a"),
      (.Vulnerability.Description // "n/a" | gsub("\n"; " ") | gsub("\r"; " "))
    ]
  | @csv
' "$INPUT" >> "$OUTPUT"

echo "CSV report written to: $OUTPUT"
