#!/usr/bin/env bash
set -euo pipefail

base_dir="/var/lib/containers/trivy"
report_dir="${base_dir}/reports"
template_dir="${base_dir}/templates"
config_dir="${base_dir}/config"
scripts_dir="${base_dir}/scripts"
timestamp=$(date +"%Y%m%d-%H%M%S")
hostname=$(hostname)

mkdir -p "$report_dir"

# Auto-detect running container images
images=$(docker ps --format '{{.Image}}' | sort -u)

for img in $images; do
  safe_name=$(echo "$img" | tr '/:' '_')
  raw_json="${report_dir}/${safe_name}-vuln-${timestamp}.json"
  filtered_json="${report_dir}/${safe_name}-vuln-${timestamp}-filtered.json"
  csv_output="${report_dir}/${safe_name}-vuln-${timestamp}.csv"
  html_output="${report_dir}/${safe_name}-vuln-${timestamp}.html"

  # JSON vulnerability scan (raw)
  docker run --rm \
    -v "${base_dir}/db:/root/.cache/trivy/db" \
    -v "$report_dir":/reports \
    -v /var/run/docker.sock:/var/run/docker.sock \
    aquasec/trivy:latest image \
      --skip-db-update \
      --skip-version-check \
      --format json \
      --output "/reports/$(basename "$raw_json")" \
      "$img"

  # Debian-only / OS-aware CVE filtering
  "${scripts_dir}/filter-cves.sh" "$raw_json" "$filtered_json"

  # CSV export from filtered JSON
  "${scripts_dir}/generate-csv.sh" "$filtered_json" "$csv_output"

  # HTML vulnerability report (using Trivy template + trivy.yaml)
  docker run --rm \
    -v "${base_dir}/db:/root/.cache/trivy/db" \
    -v "$report_dir":/reports \
    -v "$template_dir":/templates \
    -v "$config_dir":/config \
    -v /var/run/docker.sock:/var/run/docker.sock \
    aquasec/trivy:latest image \
      --skip-db-update \
      --skip-version-check \
      --format template \
      --template "@/templates/html.tpl" \
      --config /config/trivy.yaml \
      --output "/reports/$(basename "$html_output")" \
      "$img"
done
