bash
#!/bin/bash
set -euo pipefail

BASE_DIR="/var/lib/containers/trivy"
IMAGE_DIR="$BASE_DIR/images"
DB_EXPORT_DIR="$BASE_DIR/db_exports"
DB_DIR="$BASE_DIR/db"

echo "=== Trivy Import Script ==="
echo

newest_image=$(ls -1t "$IMAGE_DIR"/trivy-*.tar.gz 2>/dev/null | head -n 1 || true)

if [[ -z "$newest_image" ]]; then
    echo "ERROR: No Trivy image files found in $IMAGE_DIR"
    exit 1
fi

echo "Newest image file: $newest_image"
echo

newest_db_zip=$(ls -1t "$DB_EXPORT_DIR"/trivy-db-*.zip 2>/dev/null | head -n 1 || true)

if [[ -z "$newest_db_zip" ]]; then
    echo "ERROR: No Trivy DB zip files found in $DB_EXPORT_DIR"
    exit 1
fi

echo "Newest DB zip: $newest_db_zip"
echo

echo "Removing old Trivy images from Docker..."
docker images --format '{{.Repository}}:{{.Tag}} {{.ID}}' \
    | grep '^aquasec/trivy:' \
    | awk '{print $2}' \
    | xargs -r docker rmi -f || true
echo "Old images removed."
echo

echo "Loading new Trivy image..."
gunzip -c "$newest_image" | docker load
echo "Image loaded."
echo

echo "Cleaning old DB contents..."
rm -rf "$DB_DIR"/*
echo "DB directory cleared."
echo

echo "Extracting new DB..."
unzip -o "$newest_db_zip" -d "$DB_DIR" >/dev/null
echo "DB extracted."
echo

echo "Removing imported artifacts..."
rm -f "$newest_image"
rm -f "$newest_db_zip"
echo "Artifacts removed."
echo

echo "=== Import Complete ==="
echo "Trivy image and DB updated successfully."
echo
