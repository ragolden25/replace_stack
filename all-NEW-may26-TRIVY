bash
#!/usr/bin/env bash
set -euo pipefail

base_dir="/var/lib/containers/trivy"
report_dir="${base_dir}/reports"
template_dir="${base_dir}/templates"
config_dir="${base_dir}/config"
timestamp=$(date +"%Y%m%d-%H%M%S")
hostname=$(hostname)

mkdir -p "$report_dir"

# Auto-detect running container images
images=$(docker ps --format '{{.Image}}' | sort -u)

for img in $images; do
  safe_name=$(echo "$img" | tr '/:' '_')
  sbom_json="${report_dir}/${safe_name}-sbom-${timestamp}.json"
  sbom_cdx="${report_dir}/${safe_name}-sbom-${timestamp}.cdx"
  sbom_html="${report_dir}/${safe_name}-sbom-${timestamp}.html"

  # CycloneDX SBOM
  docker run --rm \
    -v "${base_dir}/db:/root/.cache/trivy/db" \
    -v "$report_dir":/reports \
    -v /var/run/docker.sock:/var/run/docker.sock \
    aquasec/trivy:latest image \
      --skip-db-update \
      --skip-version-check \
      --format cyclonedx \
      --output "/reports/$(basename "$sbom_cdx")" \
      "$img"

  # JSON SBOM
  docker run --rm \
    -v "${base_dir}/db:/root/.cache/trivy/db" \
    -v "$report_dir":/reports \
    -v /var/run/docker.sock:/var/run/docker.sock \
    aquasec/trivy:latest image \
      --skip-db-update \
      --skip-version-check \
      --format json \
      --output "/reports/$(basename "$sbom_json")" \
      "$img"

  # HTML SBOM with hostname (via trivy.yaml in /config)
  docker run --rm \
    -v "${base_dir}/db:/root/.cache/trivy/db" \
    -v "$report_dir":/reports \
    -v "$template_dir":/templates \
    -v "$config_dir":/config \
    -v /var/run/docker.sock:/var/run/docker.sock \
    aquasec/trivy:latest image \
      --skip-db-update \
      --skip-version-check \
      --format template \
      --template "@/templates/html.tpl" \
      --config /config/trivy.yaml \
      --output "/reports/$(basename "$sbom_html")" \
      "$img"
done
